CAMPAIGN_ID=20024
DATA_DIR=./Smadex_Creative_Intelligence_Dataset_FULL
IMAGES_DIR=./Smadex_Creative_Intelligence_Dataset_FULL/assets

# Default: local, free inference through Ollama. Run:
#   ollama pull gemma4:e2b
#   ollama serve
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_TEXT=gemma4:e2b
OLLAMA_MODEL_VISION=gemma4:e2b
OLLAMA_JSON_MODE=true
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=90

# Optional paid/cloud fallback:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL_TEXT=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL_VISION=claude-sonnet-4-6

# Optional free-tier/provider fallback if it exposes an OpenAI-compatible API:
# LLM_PROVIDER=openai_compatible
# OPENAI_COMPATIBLE_BASE_URL=https://example.com/v1
# OPENAI_COMPATIBLE_API_KEY=your_key_here
# OPENAI_COMPATIBLE_MODEL_TEXT=provider-text-model
# OPENAI_COMPATIBLE_MODEL_VISION=provider-vision-model
